# Simon's Dog Sitting - Environment Variables

# Supabase Configuration (for loading sitters from the database)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Mapbox Configuration (for real map backgrounds in Discover & LiveWalk screens)
# Get your access token from: https://account.mapbox.com/access-tokens/
# Use a token with "styles:read" scope for Static Images API
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ1Ijoi...
